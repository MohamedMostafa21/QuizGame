<!DOCTYPE html>
@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty;
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty;
    var bodyClass = $"page-{currentController.ToLowerInvariant()} page-{currentController.ToLowerInvariant()}-{currentAction.ToLowerInvariant()} app-root";
    var signedInName = User.Identity?.Name ?? "Player";
    var signedInInitial = string.IsNullOrWhiteSpace(signedInName)
        ? "P"
        : signedInName.Trim()[0].ToString().ToUpperInvariant();
}
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - QuizPulse</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@400;500;700;800&family=Orbitron:wght@500;700;800;900&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" integrity="sha512-1ycn6IcaQQ40/MKB4Imkb9uH/PrM6V8J+Nt4HkS7X1Yg4L6NqBJ38qJNmPR9U1FVLtZL1NVr7DiIP9N6byN1Eg==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/QuizGame.styles.css" asp-append-version="true" />
</head>
<body class="@bodyClass">
    <div class="ambient-orb ambient-orb-one"></div>
    <div class="ambient-orb ambient-orb-two"></div>
    <div class="grain-overlay"></div>

    <header class="app-header">
        <nav class="navbar navbar-expand-lg app-nav">
            <div class="container-fluid app-nav-inner">
                <a class="brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <span class="brand-badge" aria-hidden="true">
                        <svg viewBox="0 0 24 24" focusable="false">
                            <path d="M11.5 2l-7 10h5l-1.2 10L19 10h-5.4l1.6-8z"></path>
                        </svg>
                    </span>
                    <span class="brand-text">QuizPulse</span>
                </a>

                <button class="navbar-toggler app-nav-toggle" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav"
                        aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav app-nav-links me-auto">
                        <li class="nav-item">
                            <a class="nav-link @(currentController == "Home" ? "is-active" : string.Empty)" asp-area="" asp-controller="Home" asp-action="Index"><i class="fa-solid fa-house"></i> Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(currentController == "Lobby" ? "is-active" : string.Empty)" asp-area="" asp-controller="Lobby" asp-action="Index"><i class="fa-solid fa-play"></i> Play</a>
                        </li>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <a class="nav-link @(currentController == "QuestionBank" ? "is-active" : string.Empty)" asp-area="" asp-controller="QuestionBank" asp-action="Index"><i class="fa-solid fa-book-open"></i> Question Bank</a>
                            </li>
                        }
                    </ul>

                    <ul class="navbar-nav app-auth-links">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <span class="player-chip player-chip-rich">
                                    <span class="player-avatar-badge">@signedInInitial</span>
                                    <span class="player-meta">
                                        <span class="player-meta-label">Logged In</span>
                                        <strong>@signedInName</strong>
                                    </span>
                                    <i class="fa-solid fa-circle-check player-chip-status" aria-hidden="true"></i>
                                </span>
                            </li>
                            <li class="nav-item">
                                <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                    <button type="submit" class="btn app-btn logout-btn" title="Sign out of your account">
                                        <i class="fa-solid fa-arrow-right-from-bracket"></i> Logout
                                    </button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="btn app-btn app-btn-outline" asp-area="" asp-controller="Account" asp-action="Login"><i class="fa-solid fa-user"></i> Login</a>
                            </li>
                            <li class="nav-item">
                                <a class="btn app-btn app-btn-primary" asp-area="" asp-controller="Account" asp-action="Register"><i class="fa-solid fa-sparkles"></i> Register</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main role="main" class="app-main">
        <div class="app-shell fade-in-page">
            @RenderBody()
        </div>
    </main>

    <footer class="app-footer">
        <div class="app-footer-inner">
            <span><i class="fa-solid fa-gamepad"></i> 2026 QuizPulse</span>
            <span>Quiz. Compete. Dominate.</span>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>