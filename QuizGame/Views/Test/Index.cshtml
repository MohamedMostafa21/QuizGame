@using QuizGame.Controllers
@model IEnumerable<TestInfo>

@{
    ViewData["Title"] = "Test Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-12">
            <div class="alert alert-info">
                <h4><i class="bi bi-info-circle"></i> Test Dashboard</h4>
                <p class="mb-0">This page provides endpoints for testing LeaderboardService and ChatService functionality.</p>
                <small>These endpoints are for development purposes only. Do not use in production.</small>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-12">
            <h3>Available Tests</h3>
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>Test Name</th>
                            <th>Description</th>
                            <th>URL</th>
                            <th>Method</th>
                            <th>Auth</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var test in Model)
                        {
                            <tr>
                                <td><strong>@test.Name</strong></td>
                                <td>@test.Description</td>
                                <td><code>@test.Url</code></td>
                                <td>
                                    <span class="badge @(test.Method == "GET" ? "bg-success" : "bg-primary")">
                                        @test.Method
                                    </span>
                                </td>
                                <td>
                                    @if (test.RequiresAuth)
                                    {
                                        <span class="badge bg-warning text-dark">Required</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">None</span>
                                    }
                                </td>
                                <td>
                                    @if (test.Method == "GET")
                                    {
                                        <a class="btn btn-sm btn-outline-primary" href="@test.Url" target="_blank">
                                            <i class="bi bi-box-arrow-up-right"></i> Open
                                        </a>
                                    }
                                    else
                                    {
                                        <button class="btn btn-sm btn-outline-primary" onclick="executeTest('@test.Url', '@test.Method')">
                                            <i class="bi bi-play"></i> Run
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h5><i class="bi bi-terminal"></i> Test Execution Console</h5>
                </div>
                <div class="card-body">
                    <div id="console-output" class="bg-dark text-light p-3 rounded" style="font-family: monospace; min-height: 200px; max-height: 400px; overflow-y: auto;">
                        <div class="text-muted">// Test console ready...</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-3">
        <div class="col-12">
            <div class="alert alert-warning">
                <h6><i class="bi bi-exclamation-triangle"></i> Important Notes:</h6>
                <ul class="mb-0">
                    <li>Some tests require you to be logged in as a user</li>
                    <li>Chat tests use game ID 1 by default - ensure a game exists</li>
                    <li>Leaderboard tests require users with scores in the database</li>
                    <li>Use "Create Test Data" endpoint to set up initial test data</li>
                </ul>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function executeTest(url, method) {
            const consoleDiv = document.getElementById('console-output');
            const timestamp = new Date().toLocaleTimeString();

            // Log request
            consoleDiv.innerHTML += `<div class="text-info">[${timestamp}] ${method} ${url} ...</div>`;
            consoleDiv.scrollTop = consoleDiv.scrollHeight;

            if (method === 'POST') {
                fetch(url, {
                    method: 'POST',
                    headers: {
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || '',
                        'Content-Type': 'application/json'
                    }
                })
                .then(response => response.json())
                .then(data => {
                    const color = data.success ? 'text-success' : 'text-danger';
                    consoleDiv.innerHTML += `<div class="${color}">[${timestamp}] Response: ${JSON.stringify(data, null, 2)}</div>`;
                    consoleDiv.scrollTop = consoleDiv.scrollHeight;
                })
                .catch(error => {
                    consoleDiv.innerHTML += `<div class="text-danger">[${timestamp}] Error: ${error.message}</div>`;
                    consoleDiv.scrollTop = consoleDiv.scrollHeight;
                });
            }
        }
    </script>
}
