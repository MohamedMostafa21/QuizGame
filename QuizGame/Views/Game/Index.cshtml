@using QuizGame.ViewModels
@model GameViewModel

@{
    ViewData["Title"] = "Question";
}

<section class="lobby-page-shell">
    <div class="lobby-form-card surface-card auto-reveal">
        <p class="section-kicker">Question</p>
        <h1 class="section-title">Make Your Choice</h1>
        <p class="muted-label mb-3">Select one answer, then lock it in.</p>

        <form asp-action="SubmitAnswer" asp-controller="Game" method="post">
            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="question-box mb-3">@Model.Question.Question.Text</div>

            <div class="answers-grid mb-3">
                @for (int i = 0; i < Model.Options.Count; i++)
                {
                    <label class="answer-btn d-flex align-items-center gap-2" for="option_@Model.Options[i].Id">
                        <input class="form-check-input"
                               type="radio"
                               asp-for="Options[i].Id"
                               id="option_@Model.Options[i].Id" />
                        <span>@Model.Options[i].Text</span>
                    </label>
                }
            </div>

            <input type="hidden" asp-for="Question.Id" />
            <input type="hidden" asp-for="Player.Id" />

            <button type="submit" class="btn app-btn app-btn-primary w-100" id="submitBtn" disabled>
                Submit Answer
            </button>
        </form>
    </div>
</section>

@section Scripts {
    <!-- Validation Scripts -->
    <partial name="_ValidationScriptsPartial" />

    <script>
        const radios = document.querySelectorAll('input[type="radio"]');
        const submitBtn = document.getElementById('submitBtn');

        radios.forEach(radio => {
            radio.addEventListener('change', () => {
                submitBtn.disabled = false;
            });
        });
    </script>
}
