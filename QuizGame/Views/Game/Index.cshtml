@using QuizGame.ViewModels
@model GameViewModel

@{
    ViewData["Title"] = "Index";
}

<div class="container mt-5">

    <!-- Question Card -->
    <div class="card shadow-sm">
        <div class="card-body">

            <h4 class="card-title mb-4">
                @Model.Question.Question.Text
            </h4>

            <form asp-action="SubmitAnswer" asp-controller="Game" method="post">

                <!-- Validation -->
                <div asp-validation-summary="All" class="text-danger mb-3"></div>

                <!-- Options -->
                <div class="mb-4">
                    @for (int i = 0; i < Model.Options.Count; i++)
                    {
                        <div class="form-check mb-2">

                            <input class="form-check-input"
                                   type="radio"
                                   asp-for="Options[i].Id"
                                   id="option_@Model.Options[i].Id" />

                            <label class="form-check-label" for="option_@Model.Options[i].Id">
                                @Model.Options[i].Text
                            </label>

                        </div>
                    }
                </div>

                <!-- Hidden fields -->
                <input type="hidden" asp-for="Question.Id" />
                <input type="hidden" asp-for="Player.Id" />

                <!-- Submit Button -->
                <button type="submit" class="btn btn-primary w-100" id="submitBtn" disabled>
                    Submit Answer
                </button>

            </form>

        </div>
    </div>

</div>

@section Scripts {
    <!-- Validation Scripts -->
    <partial name="_ValidationScriptsPartial" />

    <script>
        const radios = document.querySelectorAll('input[type="radio"]');
        const submitBtn = document.getElementById('submitBtn');

        radios.forEach(radio => {
            radio.addEventListener('change', () => {
                submitBtn.disabled = false;
            });
        });
    </script>
}
