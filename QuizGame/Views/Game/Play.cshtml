@* REDESIGNED: Active Game Play - Premium Gaming UI *@
@model QuizGame.ViewModels.GamePlayViewModel

@{
    ViewData["Title"] = "Game";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var tileClasses = new[] { "answer-red", "answer-blue", "answer-yellow", "answer-green" };
    var tileShapes = new[] { "▲", "△", "●", "■" };
}

<input type="hidden" id="roomCode" value="@Model.RoomCode" />
<input type="hidden" id="gameId" value="@Model.GameId" />

<section class="play-shell">
    <header class="play-topbar glass-panel auto-reveal">
        <div class="top-left">
            <span class="kicker-mini">Question</span>
            <strong class="question-counter" id="questionCounter">
                @(Model.ActiveQuestion != null
                    ? $"Q {Model.ActiveQuestion.Order} / {Model.ActiveQuestion.TotalQuestions}"
                    : "Q -- / --")
            </strong>
        </div>

        <div class="timer-ring-shell">
            <svg class="timer-ring-svg" viewBox="0 0 132 132" aria-hidden="true">
                <circle class="timer-ring-base" cx="66" cy="66" r="52"></circle>
                <circle class="timer-ring-progress" id="timerRing" cx="66" cy="66" r="52"></circle>
            </svg>
            <span class="timer-value" id="timerText">@(Model.ActiveQuestion?.TimeLimitSeconds ?? 0)s</span>
        </div>

        <div class="top-right">
            <span class="rank-pill" id="myRank">Rank: --</span>
            <strong class="score-pill" id="myScore">0 pts</strong>
        </div>
    </header>

    <article class="question-stage glass-panel auto-reveal" id="questionStage">
        <div class="question-card">
            <h2 class="question-text" id="questionText">@(Model.ActiveQuestion?.Text ?? "Waiting for next question...")</h2>
        </div>

        <div class="q-progress-track">
            <div class="q-progress" id="questionProgress"></div>
        </div>

        <div id="answerButtons" class="answer-grid">
            @if (Model.ActiveQuestion != null)
            {
                for (var i = 0; i < Model.ActiveQuestion.Options.Count; i++)
                {
                    var option = Model.ActiveQuestion.Options[i];
                    var color = tileClasses[i % tileClasses.Length];
                    var shape = tileShapes[i % tileShapes.Length];

                    <button class="answer-tile @color"
                            data-id="@option.Id"
                            data-index="@i"
                            onclick="submitAnswer(@option.Id, this)">
                        <span class="answer-left">
                            <span class="answer-shape">@shape</span>
                            <span>@option.Text</span>
                        </span>
                        <span class="answer-icon"></span>
                    </button>
                }
            }
        </div>

        <div class="floating-points" id="floatingPoints">+100</div>
    </article>

    <div class="play-bottom-row">
        <section class="mini-board glass-panel auto-reveal">
            <h3 class="mb-3"><i class="fa-solid fa-ranking-star"></i> Top 3 Live</h3>
            <div class="mini-list" id="miniLeaderboard"></div>
        </section>

        <section class="chat-panel glass-panel auto-reveal">
            <h3 class="mb-3"><i class="fa-solid fa-comments"></i> Squad Chat</h3>
            <div id="chatMessages" class="chat-list"></div>
            <div class="chat-input-row">
                <input id="chatInput"
                       class="form-control"
                       type="text"
                       placeholder="Type a message..."
                       maxlength="180"
                       onkeydown="if(event.key==='Enter') sendChat()" />
                <button onclick="sendChat()" class="btn btn-glass" type="button">
                    <i class="fa-solid fa-paper-plane"></i>
                </button>
            </div>
        </section>
    </div>
</section>

@await Html.PartialAsync("_RoundResultOverlay")

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script>
        (function () {
            const roomCode = document.getElementById("roomCode").value;
            const currentUserName = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(User.Identity?.Name ?? string.Empty));

            const timerRing = document.getElementById("timerRing");
            const timerText = document.getElementById("timerText");
            const questionProgress = document.getElementById("questionProgress");
            const answerButtonsContainer = document.getElementById("answerButtons");
            const questionCounter = document.getElementById("questionCounter");
            const questionText = document.getElementById("questionText");
            const miniLeaderboard = document.getElementById("miniLeaderboard");
            const myRank = document.getElementById("myRank");
            const myScore = document.getElementById("myScore");
            const floatingPoints = document.getElementById("floatingPoints");

            const roundOverlay = document.getElementById("roundOverlay");
            const roundOverlayIcon = document.getElementById("roundOverlayIcon");
            const roundOverlayTitle = document.getElementById("roundOverlayTitle");
            const roundOverlaySubtitle = document.getElementById("roundOverlaySubtitle");
            const roundOverlayRank = document.getElementById("roundOverlayRank");
            const roundOverlayProgress = document.getElementById("roundOverlayProgress");

            const colorClasses = ["answer-red", "answer-blue", "answer-yellow", "answer-green"];
            const shapeSymbols = ["▲", "△", "●", "■"];

            const ringRadius = 52;
            const ringCircumference = 2 * Math.PI * ringRadius;
            timerRing.style.strokeDasharray = ringCircumference;
            timerRing.style.strokeDashoffset = 0;

            let timerInterval = null;
            let overlayInterval = null;
            let overlayTimeout = null;
            let answeredThisRound = false;
            let selectedOptionId = null;
            let latestScores = [];

            function getMyStats(scores) {
                const rank = scores.findIndex(player => player.userName === currentUserName);
                if (rank === -1) {
                    return { rankText: "Rank: --", scoreText: "0 pts" };
                }

                return {
                    rankText: `Rank: #${rank + 1}`,
                    scoreText: `${scores[rank].score} pts`
                };
            }

            function renderMiniLeaderboard(scores) {
                miniLeaderboard.innerHTML = "";

                if (!scores || !scores.length) {
                    const placeholder = document.createElement("div");
                    placeholder.className = "placeholder-state";
                    placeholder.textContent = "Leaderboard will appear after the first score update.";
                    miniLeaderboard.appendChild(placeholder);
                    return;
                }

                scores.slice(0, 3).forEach(function (player, index) {
                    const row = document.createElement("div");
                    row.className = "mini-row";
                    row.innerHTML = `
                        <span>${index + 1}. ${player.userName}</span>
                        <strong>${player.score}</strong>
                    `;
                    miniLeaderboard.appendChild(row);
                });
            }

            function updatePlayerHud(scores) {
                latestScores = scores || [];
                renderMiniLeaderboard(latestScores);

                const stats = getMyStats(latestScores);
                myRank.textContent = stats.rankText;
                myScore.textContent = stats.scoreText;
            }

            function setTimerVisual(remaining, total) {
                const safeTotal = Math.max(1, total);
                const ratio = Math.max(0, remaining / safeTotal);
                const dashOffset = ringCircumference * (1 - ratio);

                timerRing.style.strokeDashoffset = dashOffset;
                timerRing.classList.toggle("danger", remaining <= 5);
                questionProgress.classList.toggle("danger", remaining <= 5);
                questionProgress.style.width = `${ratio * 100}%`;
                timerText.textContent = `${Math.max(0, remaining)}s`;
            }

            function startTimer(seconds) {
                clearInterval(timerInterval);
                const total = Math.max(1, seconds);
                let remaining = total;

                setTimerVisual(remaining, total);

                timerInterval = window.setInterval(function () {
                    remaining -= 1;
                    setTimerVisual(remaining, total);

                    if (remaining <= 0) {
                        clearInterval(timerInterval);
                    }
                }, 1000);
            }

            function hideRoundOverlay() {
                roundOverlay.classList.remove("active");
                clearInterval(overlayInterval);
                clearTimeout(overlayTimeout);
            }

            function showRoundOverlay(icon, title, subtitle) {
                hideRoundOverlay();

                roundOverlayIcon.textContent = icon;
                roundOverlayTitle.textContent = title;
                roundOverlaySubtitle.textContent = subtitle;

                const stats = getMyStats(latestScores);
                roundOverlayRank.textContent = stats.rankText === "Rank: --"
                    ? "Rank syncing..."
                    : `Current ${stats.rankText.toLowerCase()}`;

                roundOverlayProgress.style.width = "100%";
                roundOverlay.classList.add("active");

                let remainingMs = 3000;
                overlayInterval = window.setInterval(function () {
                    remainingMs -= 30;
                    const ratio = Math.max(0, remainingMs / 3000);
                    roundOverlayProgress.style.width = `${ratio * 100}%`;
                }, 30);

                overlayTimeout = window.setTimeout(function () {
                    hideRoundOverlay();
                }, 3000);
            }

            function lockAnswers() {
                document.querySelectorAll(".answer-tile").forEach(function (button) {
                    button.disabled = true;
                });
            }

            function unlockAnswers() {
                document.querySelectorAll(".answer-tile").forEach(function (button) {
                    button.disabled = false;
                    button.classList.remove("selected", "correct", "wrong", "dim");
                    const icon = button.querySelector(".answer-icon");
                    if (icon) {
                        icon.innerHTML = "";
                    }
                });
            }

            function markCorrectAnswer(correctOptionId) {
                document.querySelectorAll(".answer-tile").forEach(function (button) {
                    const icon = button.querySelector(".answer-icon");
                    const optionId = parseInt(button.dataset.id, 10);

                    if (optionId === correctOptionId) {
                        button.classList.add("correct");
                        if (icon) {
                            icon.innerHTML = '<i class="fa-solid fa-check"></i>';
                        }
                    } else {
                        button.classList.add("dim");
                    }
                });
            }

            function showFloatingPoints(points) {
                floatingPoints.textContent = `+${points}`;
                floatingPoints.classList.remove("show");
                void floatingPoints.offsetWidth;
                floatingPoints.classList.add("show");
            }

            function answerTemplate(option, optionIndex, gameQuestionId) {
                const colorClass = colorClasses[optionIndex % colorClasses.length];
                const shape = shapeSymbols[optionIndex % shapeSymbols.length];

                const button = document.createElement("button");
                button.className = `answer-tile ${colorClass}`;
                button.dataset.id = option.id;
                button.dataset.index = optionIndex;
                button.dataset.gqid = gameQuestionId;
                button.type = "button";
                button.innerHTML = `
                    <span class="answer-left">
                        <span class="answer-shape">${shape}</span>
                        <span>${option.text}</span>
                    </span>
                    <span class="answer-icon"></span>
                `;
                button.addEventListener("click", function () {
                    submitAnswer(option.id, button);
                });

                return button;
            }

            window.submitAnswer = function submitAnswer(optionId, button) {
                if (answeredThisRound) {
                    return;
                }

                answeredThisRound = true;
                selectedOptionId = optionId;

                lockAnswers();
                button.classList.add("selected");

                const gameQuestionId = parseInt(button.dataset.gqid, 10);
                if (Number.isNaN(gameQuestionId)) {
                    return;
                }

                connection.invoke("SubmitAnswer", roomCode, gameQuestionId, optionId);
            };

            window.sendChat = function sendChat() {
                const chatInput = document.getElementById("chatInput");
                const text = chatInput.value.trim();
                if (!text) {
                    return;
                }

                connection.invoke("SendChatMessage", roomCode, text);
                chatInput.value = "";
            };

            function renderQuestion(question) {
                hideRoundOverlay();
                clearInterval(timerInterval);

                answeredThisRound = false;
                selectedOptionId = null;

                questionCounter.textContent = `Q ${question.order} / ${question.totalQuestions}`;
                questionText.textContent = question.text;

                answerButtonsContainer.innerHTML = "";
                (question.options || []).forEach(function (option, index) {
                    answerButtonsContainer.appendChild(answerTemplate(option, index, question.gameQuestionId));
                });

                startTimer(question.timeLimitSeconds || 1);
            }

            function appendChat(message) {
                const chatBox = document.getElementById("chatMessages");
                const row = document.createElement("div");
                row.className = "chat-row" + (message.userName === "System" ? " system" : "");
                row.innerHTML = `
                    <div class="chat-meta">
                        <strong>${message.userName}</strong>
                        <span>${message.sentAt || ""}</span>
                    </div>
                    <div>${message.text}</div>
                `;

                chatBox.appendChild(row);
                chatBox.scrollTop = chatBox.scrollHeight;
            }

            const connection = new signalR.HubConnectionBuilder()
                .withUrl("/hubs/game")
                .withAutomaticReconnect()
                .build();

            connection.on("NextQuestion", function (question) {
                renderQuestion(question);
            });

            connection.on("RoundWon", function (data) {
                clearInterval(timerInterval);
                lockAnswers();
                markCorrectAnswer(data.correctAnswerOptionId);
                updatePlayerHud(data.scoreboard || []);
                showRoundOverlay("✅", "CORRECT ANSWER LOCKED", `${data.winnerUserName} scored +${data.pointsAwarded}`);
            });

            connection.on("RoundTimedOut", function (data) {
                clearInterval(timerInterval);
                lockAnswers();
                markCorrectAnswer(data.correctAnswerOptionId);
                updatePlayerHud(data.scoreboard || []);
                showRoundOverlay("❌", "TIME UP", `No winner. Correct answer has been revealed.`);
            });

            connection.on("AnswerResult", function (data) {
                if (!selectedOptionId) {
                    return;
                }

                const selectedButton = Array.from(document.querySelectorAll(".answer-tile")).find(function (button) {
                    return parseInt(button.dataset.id, 10) === selectedOptionId;
                });

                if (!selectedButton) {
                    return;
                }

                const icon = selectedButton.querySelector(".answer-icon");

                if (data.isCorrect) {
                    selectedButton.classList.add("correct");
                    if (icon) {
                        icon.innerHTML = '<i class="fa-solid fa-check"></i>';
                    }
                    showFloatingPoints(data.pointsAwarded || 100);
                } else {
                    selectedButton.classList.add("wrong");
                    if (icon) {
                        icon.innerHTML = '<i class="fa-solid fa-xmark"></i>';
                    }
                }
            });

            connection.on("AnswerRejected", function (message) {
                answeredThisRound = false;
                unlockAnswers();
                showRoundOverlay("⚠️", "ANSWER REJECTED", message);
            });

            connection.on("ChatMessageReceived", function (message) {
                appendChat(message);
            });

            connection.on("PlayerConnected", function (name) {
                appendChat({ userName: "System", text: `${name} joined`, sentAt: "" });
            });

            connection.on("PlayerDisconnected", function (name) {
                appendChat({ userName: "System", text: `${name} left`, sentAt: "" });
            });

            connection.on("GameOver", function () {
                showRoundOverlay("🏆", "MATCH COMPLETE", "Redirecting to final leaderboard...");
                window.setTimeout(function () {
                    window.location.href = `/Game/Summary?roomCode=${encodeURIComponent(roomCode)}`;
                }, 2000);
            });

            connection.start().then(function () {
                return connection.invoke("JoinGameRoom", roomCode);
            }).catch(function (err) {
                console.error(err.toString());
                showRoundOverlay("⚠️", "CONNECTION ISSUE", "Trying to reconnect...");
            });

            @if (Model.ActiveQuestion != null)
            {
                <text>
                    document.querySelectorAll(".answer-tile").forEach(function (button) {
                        button.dataset.gqid = "@Model.ActiveQuestion.GameQuestionId";
                    });
                    startTimer(@Model.ActiveQuestion.TimeLimitSeconds);
                </text>
            }

            updatePlayerHud([]);
        })();
    </script>
}
