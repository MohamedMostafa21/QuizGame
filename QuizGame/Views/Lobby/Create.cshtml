@* REDESIGNED: Host Create Room - Premium Gaming UI *@
@model QuizGame.ViewModels.CreateGameViewModel

@{
    ViewData["Title"] = "Host Setup";
    var categoryList = new SelectList(Model.Categories, "Id", "Name");
}

<section class="host-page">
    <article class="mission-control glass-panel auto-reveal">
        <p class="section-kicker">Mission Control</p>
        <h1 class="section-title">Configure Your Match</h1>
        <p class="muted-label mb-3">Tune the round, invite players, and launch when your squad is ready.</p>

        <form asp-controller="Lobby" asp-action="Create" method="post" class="host-form">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="CategoryId" class="form-label">Question Category</label>
                <select class="form-select" asp-for="CategoryId" asp-items="categoryList">
                    <option value="">All Categories</option>
                </select>
                <span asp-validation-for="CategoryId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="QuestionCount" class="form-label">Question Count</label>
                <input type="number"
                       min="1"
                       max="20"
                       class="form-control"
                       asp-for="QuestionCount"
                       placeholder="Choose 1 to 20" />
                <span asp-validation-for="QuestionCount" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-neon btn-pulse w-100 mt-2">
                <i class="fa-solid fa-circle-plus"></i> Create Room
            </button>
        </form>
    </article>

    <aside class="host-note glass-panel auto-reveal">
        <p class="section-kicker">After Creating</p>
        <ul>
            <li>Share the generated room code.</li>
            <li>Track live joins in the waiting room.</li>
            <li>Start only when enough players are connected.</li>
        </ul>
    </aside>
</section>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
